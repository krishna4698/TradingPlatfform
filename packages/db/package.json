{
  "name": "@repo/db",
  "private": true,
  "version": "1.0.0",
  "type": "module",

  "main": "dist/index.js",
  "types": "dist/index.d.ts",

  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },

  "files": [
    "dist",
    "prisma"
  ],

  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.json",
    "db:generate": "prisma generate",
