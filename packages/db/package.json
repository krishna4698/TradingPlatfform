    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:test":"tsx scripts/test-database.ts"
  },

  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "dotenv": "^17.4.2"
  },

  "devDependencies": {
    "@repo/typescript-config": "*",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.15.5",
    "pg": "^8.16.3",
    "prisma": "^7.7.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  }
}
